# puhekieli-llm environment config
# Copy this to `.env` (gitignored) and fill in your values:
#   cp .env.example .env
# config.py auto-loads .env, so notebooks pick these up automatically.
# Real shell env vars override .env values.

# --- Genius API (rap lyrics, 01_collect.ipynb) ---
# Get a free "Client Access Token" at https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=

# --- LM Studio (back-translation, 01b_synthesize.ipynb) ---
# Point at your LM Studio server. Default is localhost; set your LAN IP if remote.
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_MODEL=gpt-oss-20b
# LMSTUDIO_API_KEY is ignored by LM Studio; leave as-is.
LMSTUDIO_API_KEY=lm-studio

# --- OpenSubtitles (01_collect.ipynb section B) ---
# Set to 1 to allow the ~870 MB one-time download.
# FETCH_OPENSUBS=1
